// domain/entities.rs

enum ModeType {           // serde Serialize + Deserialize
    Sniper,
    ArSmg,
    Shotgun,
}

enum StepAction {
    RightClick,
    LeftClick,
    Switch(SwitchMode),
}

enum SwitchMode {         // serde Serialize + Deserialize
    QQ,
    Num31,
}

struct SequenceStep {
    action: StepAction,
    delay_ms: u32,          // 0..100
}

struct SniperSequence {
    steps: Vec<SequenceStep>,   // 4 steps: RightClick, LeftClick, RightClick, Switch
}

enum Key {
    Q,
    Key1,
    Key3,
}


// domain/ports.rs

trait InputEnginePort: Send + Sync {
    fn right_click(&self);
    fn left_click(&self);
    fn press(&self, key: Key);
    fn release(&self, key: Key);
    fn move_mouse_relative(&self, dx: i32, dy: i32);
}

trait ConfigPort: Send {
    fn load(&mut self);
    fn save(&self);
}


// app/state.rs

struct AppConfig {          // serde Serialize + Deserialize
    buka_delay_ms: u32,         // default: 70
    tembak_delay_ms: u32,       // default: 30
    tutup_delay_ms: u32,        // default: 50
    ganti_delay_ms: u32,        // default: 50
    switch_mode: SwitchMode,    // default: QQ
    toggle_key: String,         // default: "F12"
    current_mode: ModeType,     // default: Sniper
    ar_delay_ms: u32,           // default: 50
    ar_recoil_enabled: bool,    // default: false
    ar_recoil_pixels: i32,      // default: 10
    shotgun_tembak_delay_ms: u32, // default: 30
    shotgun_ganti_delay_ms: u32,  // default: 50
}

struct AppState {
    active: AtomicBool,
    config: Mutex<AppConfig>,
}


// infra/ui_eframe.rs

struct PbscriptApp {
    state: Arc<AppState>,
    config_cache: AppConfig,
}


